# Database URL (required for Vercel/production)
# Example for PostgreSQL: postgresql://user:password@host:5432/dbname
# On Vercel, set this as an environment variable
DATABASE_URL=

# Django secret key (required for Vercel/production)
# Generate a new one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Debug mode (set to False on production)
DEBUG=False
